# Vietnamese Algorithmic Trading System - Environment Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL / TimescaleDB
POSTGRES_DB=finstock_metadata
POSTGRES_USER=finstock_user
POSTGRES_PASSWORD=<GENERATE_RANDOM_PASSWORD_HERE>
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================

MINIO_ROOT_USER=finstock_admin
MINIO_ROOT_PASSWORD=<GENERATE_RANDOM_PASSWORD_HERE>
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# =============================================================================
# MESSAGE BROKER (Kafka)
# =============================================================================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# =============================================================================
# WORKFLOW ORCHESTRATION (Airflow)
# =============================================================================

AIRFLOW_UID=50000
AIRFLOW_DB_PASSWORD=<GENERATE_RANDOM_PASSWORD_HERE>
AIRFLOW__CORE__FERNET_KEY=<GENERATE_WITH: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())">
AIRFLOW__WEBSERVER__SECRET_KEY=<GENERATE_WITH: openssl rand -hex 32>
AIRFLOW_ADMIN_PASSWORD=<GENERATE_RANDOM_PASSWORD_HERE>
AIRFLOW__CORE__LOAD_EXAMPLES=false

# =============================================================================
# MONITORING (Grafana)
# =============================================================================

GF_SECURITY_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<GENERATE_RANDOM_PASSWORD_HERE>

# =============================================================================
# VIETNAMESE MARKET CONFIGURATION
# =============================================================================

VIETNAM_TIMEZONE=Asia/Ho_Chi_Minh
TRADING_MODE=paper
MAX_POSITION_SIZE=100000000
MAX_PORTFOLIO_VALUE=1000000000
CURRENCY=VND

# =============================================================================
# API CONFIGURATION
# =============================================================================

# VnStock API
VNSTOCK_SOURCE=vci
VNSTOCK_RATE_LIMIT=10
VNSTOCK_TIMEOUT=30

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================

ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
PYTHONPATH=./src
